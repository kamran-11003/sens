# Prisma uses DATABASE_URL from .env.local automatically via dotenv cascade.
# For local dev override, set here. For production, set DATABASE_URL in your host env.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ric_auth"
# DIRECT_URL is required by the schema when using a connection pooler (Supabase).
# For local dev it's the same as DATABASE_URL (direct connection, no pooler).
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/ric_auth"
